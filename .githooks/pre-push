#!/bin/sh
# pre-push: guard against force pushes, optionally run MATLAB checks
# Timeout for MATLAB test suite (seconds). If tests exceed this, push is
# allowed with a warning and the event is logged to .agent/logs/.
TIMEOUT_SECONDS=300
LOG_DIR=".agent/logs"

echo "=== pre-push: running checks..."

# 1. Reject force pushes
# Git sets GIT_PUSH_OPTION_COUNT for --force-with-lease options,
# but there's no simple env variable for --force. Detect via refspec.
# If the push is forced, the hook runs with a non-zero exit status
# from git's own pre-push logic. We check an alternative way:
# The FORCED variable is set by git in some versions.
# Simplest: refuse any push with --force by checking if this is
# a non-fast-forward update.
# Actually, the safest check: warn the user.
# Git doesn't pass --force info to pre-push easily.
# Best we can do: check if remote ref already exists and would be
# overwritten (non-fast-forward).

ZERO_HASH="0000000000000000000000000000000000000000"

while read local_ref local_oid remote_ref remote_oid; do
    if [ "$remote_oid" != "$ZERO_HASH" ]; then
        # Remote ref exists — check if this is a fast-forward
        if ! git merge-base --is-ancestor "$remote_oid" "$local_oid" 2>/dev/null; then
            echo "ERROR: Force push detected to $remote_ref"
            echo "The project rules forbid force pushes."
            echo "    (see AGENTS.md: 'No force push, no amend')"
            exit 1
        fi
    fi
done

# 2. Optionally run MATLAB lint + tests if MATLAB is available
if command -v matlab >/dev/null 2>&1; then
    LINT_SCRIPT=".agent/skills/lint/scripts/lintCode.m"
    if [ -f "$LINT_SCRIPT" ]; then
        echo "MATLAB found — running lint..."
        matlab -batch "addpath('.agent/skills/lint/scripts'); lintCode();"
        if [ $? -ne 0 ]; then
            echo "ERROR: Lint failed — fix before pushing"
            exit 1
        fi
    else
        echo "Lint script not found at $LINT_SCRIPT — skipping lint"
    fi
    echo "Running tests (timeout: ${TIMEOUT_SECONDS}s)..."
    timeout $TIMEOUT_SECONDS matlab -batch "ROOT=pwd; addpath(ROOT); addpath(fullfile(ROOT,'tests')); import matlab.unittest.TestSuite; suite = TestSuite.fromFolder(fullfile(ROOT,'tests','+robot'), 'IncludingSubfolders', true); fleetFile = fullfile(ROOT,'tests','RobotFleetAppTest.m'); if isfile(fleetFile); fleetSuite = TestSuite.fromFile(fleetFile); suite = [suite(:); fleetSuite(:)]; end; results = run(suite); assertSuccess(results);"
    EXIT_CODE=$?
    if [ $EXIT_CODE -eq 0 ]; then
        echo "=== pre-push: lint + tests passed ==="
    elif [ $EXIT_CODE -eq 124 ]; then
        TIMESTAMP=$(date +%Y%m%d-%H%M%S)
        mkdir -p "$LOG_DIR"
        LOG_FILE="$LOG_DIR/pre-push-timeout-$TIMESTAMP.log"
        echo "[$TIMESTAMP] MATLAB test suite timed out after ${TIMEOUT_SECONDS}s" > "$LOG_FILE"
        echo "WARNING: MATLAB test suite timed out after ${TIMEOUT_SECONDS}s."
        echo "WARNING: Push allowed with --no-verify. Event logged to $LOG_FILE"
    else
        echo "ERROR: Tests failed (exit $EXIT_CODE) — fix before pushing"
        exit 1
    fi
else
    echo "MATLAB not on PATH — skipping lint and tests"
fi

echo "=== pre-push: all checks passed ==="
