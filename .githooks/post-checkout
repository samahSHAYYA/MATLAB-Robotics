#!/bin/sh
# post-checkout: seed WarmStart.md if it does not exist

WARMSTART="WarmStart.md"
TEMPLATE='# WarmStart — Session Memory

Auto-generated by opencode. Preserves state across sessions for rapid context recovery.

---

## First session

_Initialized: _________

**Goal**: (describe what this session aims to accomplish)

### TODO today
-

### Discoveries / decisions
-

### Next steps
-
'

if [ ! -f "$WARMSTART" ]; then
    # Fill in the date
    TODAY=$(date "+%Y-%m-%d")
    echo "$TEMPLATE" | sed "s/_________/$TODAY/" > "$WARMSTART"
    echo "post-checkout: created $WARMSTART — edit the goal and TODO before starting"
fi

exit 0
